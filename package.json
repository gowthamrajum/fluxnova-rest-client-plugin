{
  "name": "fluxnova-rest-client-plugin",
  "version": "0.4.0",
  "description": "Postman-style REST client popup for Connector Service Tasks in the FluxNova / Camunda 7 Modeler — build, send (CORS-free via a main-process proxy), map outputs, define technical & business exception handling, and save back to the connector.",
  "main": "index.js",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "camunda",
    "camunda-modeler",
    "camunda-modeler-plugin",
    "fluxnova",
    "finos",
    "bpmn",
    "rest-client",
    "http-connector"
  ],
  "author": "gowthamrajum <gowthamrajum@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gowthamrajum/fluxnova-rest-client-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/gowthamrajum/fluxnova-rest-client-plugin/issues"
  },
  "homepage": "https://github.com/gowthamrajum/fluxnova-rest-client-plugin#readme",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "index.js",
    "menu.js",
    "client/",
    "dist/",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "dependencies": {
    "camunda-modeler-plugin-helpers": "^6.0.0",
    "preact": "^10.29.7"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.10.0",
    "style-loader": "^3.3.4",
    "vitest": "^2.1.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  }
}
